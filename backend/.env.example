# Copy to .env locally. On Railway, set these in the dashboard (never commit secrets).

# CORS: comma-separated origins (no trailing slashes on URLs)
ALLOWED_ORIGINS=http://localhost:5173

# imgBB (report gallery / sector icons) is configured in the **frontend** repo root `.env` as `VITE_IMGBB_API_KEY` — not here.

# Supabase (server-side; use service_role only if RAG needs to bypass RLS — keep off GitHub)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# JWT verification: use Supabase JWT secret from Dashboard → Settings → API (legacy) or JWKS flow in code
SUPABASE_JWT_SECRET=

# LLM (when you add RAG)
# OPENAI_API_KEY=
